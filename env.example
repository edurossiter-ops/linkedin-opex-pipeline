# Anthropic API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn Access Token
# Get yours at: https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=...

# LinkedIn Person URN
# Format: urn:li:person:XXXXXX
# Retrieve by calling GET https://api.linkedin.com/v2/me with your token
LINKEDIN_PERSON_URN=urn:li:person:XXXXXX

# Dry Run (true = generate only, do not publish)
DRY_RUN=false
